# Copy to serving/.env and fill in. Values come from your ~/clearml.conf.
#
# Networking notes (self-hosted ClearML on the same machine, macOS Docker Desktop):
#  * API/WEB are reached from the serving containers via host.docker.internal.
#  * FILES must use the host LAN IP so the absolute model-weight URLs stored by the
#    agent resolve BOTH on the host and inside the serving container.
#    (host.docker.internal does not resolve on the host, only in containers.)

CLEARML_API_HOST=http://host.docker.internal:8008
CLEARML_WEB_HOST=http://host.docker.internal:8080
CLEARML_FILES_HOST=http://192.168.88.246:8081

CLEARML_API_ACCESS_KEY=<your-clearml-access-key>
CLEARML_API_SECRET_KEY=<your-clearml-secret-key>

# Filled in after `clearml-serving create` (Stage 4).
CLEARML_SERVING_TASK_ID=

# The inference image ships sklearn 1.2.2; PIN the training version (1.9.0) or the
# pickled TF-IDF unpickles wrong ("idf vector is not fitted"). Match train.py's sklearn.
CLEARML_EXTRA_PYTHON_PACKAGES=scikit-learn==1.9.0 pandas joblib==1.5.3

# Endpoint base URL advertised by the service (host port is 9090).
CLEARML_DEFAULT_BASE_SERVE_URL=http://127.0.0.1:9090/serve
